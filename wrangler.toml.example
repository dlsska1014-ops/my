name = "ttokttok-accountbook"
main = "src/index.js"
compatibility_date = "2026-07-15"

[vars]
APP_NAME = "똑똑한가계부"
PUBLIC_BASE_URL = "https://ttokttok-accountbook.com"
INCOMPLETE_FEATURE_QA_ENABLED = "0"
MEME_CARDS_ENABLED = "0"
CARD_PERFORMANCE_ENABLED = "0"

[triggers]
crons = ["10 0 * * *"]

# 실제 값은 이 파일에 쓰지 말고 `wrangler secret put 이름`으로 등록하세요.
# 필수: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, ADMIN_SESSION_SECRET,
#       USER_SESSION_SECRET, ADMIN_API_TOKEN, MY_IMPORT_TOKEN_SECRET
# 선택: ADMIN_PASSWORD(최초 부트스트랩), KAKAO_REST_API_KEY,
#       KAKAO_CLIENT_SECRET, CRON_SECRET
